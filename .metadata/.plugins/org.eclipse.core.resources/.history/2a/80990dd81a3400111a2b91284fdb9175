<%
Connection conn = getConnection();

if(conn == null){
    System.out.println("Database connection failed!");
    return;
}

Statement stmt = null;

try {
    stmt = conn.createStatement();

    stmt.executeUpdate("CREATE TABLE IF NOT EXISTS intents (" +
                       "id SERIAL PRIMARY KEY, " +
                       "intent_name VARCHAR(50) UNIQUE NOT NULL)");

    stmt.executeUpdate("CREATE TABLE IF NOT EXISTS responses (" +
                       "id SERIAL PRIMARY KEY, " +
                       "intent_id INT REFERENCES intents(id), " +
                       "response_text TEXT NOT NULL)");

    stmt.executeUpdate("CREATE TABLE IF NOT EXISTS chat_logs (" +
                       "id SERIAL PRIMARY KEY, " +
                       "user_message TEXT, " +
                       "bot_response TEXT, " +
                       "timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP)");

    out.println("Tables created successfully!");

} catch(Exception e) {
    System.out.println("Error: " + e.getMessage());
    e.printStackTrace();
} finally {
    try {
        if(stmt != null) stmt.close();
        if(conn != null) conn.close();
    } catch(Exception e) {
        e.printStackTrace();
    }
}
%>

