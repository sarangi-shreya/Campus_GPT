<%
Connection conn = getConnection();
Statement stmt = null;

try {
    stmt = conn.createStatement();

    // Create intents table
    String intentsTable = "CREATE TABLE IF NOT EXISTS intents (" +
                          "id SERIAL PRIMARY KEY, " +
                          "intent_name VARCHAR(50) UNIQUE NOT NULL" +
                          ")";
    stmt.executeUpdate(intentsTable);

    // Create responses table
    String responsesTable = "CREATE TABLE IF NOT EXISTS responses (" +
                            "id SERIAL PRIMARY KEY, " +
                            "intent_id INT REFERENCES intents(id), " +
                            "response_text TEXT NOT NULL" +
                            ")";
    stmt.executeUpdate(responsesTable);

    // Create chat_logs table
    String chatLogsTable = "CREATE TABLE IF NOT EXISTS chat_logs (" +
                           "id SERIAL PRIMARY KEY, " +
                           "user_message TEXT, " +
                           "bot_response TEXT, " +
                           "timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP" +
                           ")";
    stmt.executeUpdate(chatLogsTable);

    out.println("Tables created successfully!");

} catch(Exception e) {
    out.println("Error: " + e.getMessage());
    e.printStackTrace();
} finally {
    try {
        if(stmt != null) stmt.close();
        if(conn != null) conn.close();
    } catch(Exception e) {
        e.printStackTrace();
    }
}
